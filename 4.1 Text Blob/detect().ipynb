   "source": [
    "from langdetect import detect\n",
    "from textblob import TextBlob\n",
    "\n",
    "text = \"میں کامسیٹس یونیورسٹی میں مصنوعی ذہانت کا طالب علم ہوں۔\"\n",
    "\n",
    "blob = TextBlob(text)\n",
    "\n",
    "language = detect(blob.raw)\n",
    "\n",
    "print(\"Language used: \",language)\n"
   ]
