   "source": [
    "from textblob import Word\n",
    "\n",
    "input = input(\"Enter a word to lemmatize: \")\n",
    "\n",
    "word_obj = Word(input)\n",
    "\n",
    "lemmatized_word = word_obj.lemmatize('v')  # 'v' for verb\n",
    "\n",
    "print(\"Lemmatized word =\",lemmatized_word)\n"
   ]
