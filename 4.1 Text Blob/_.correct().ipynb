   "source": [
    "from textblob import TextBlob\n",
    "\n",
    "\n",
    "text = input(\"Enter your text: \")\n",
    "\n",
    "blob = TextBlob(text)\n",
    "\n",
    "corrected_blob = blob.correct()\n",
    "\n",
    "print(\"Corrected text:\" ,corrected_blob)\n"
   ]
