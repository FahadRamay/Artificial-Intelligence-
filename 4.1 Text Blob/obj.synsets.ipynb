   "source": [
    "from textblob import Word\n",
    "text = input(\"Enter a word to find synonyms: \")\n",
    "\n",
    "word_obj = Word(text)\n",
    "\n",
    "synsets = word_obj.synsets\n",
    "print('Synonyms in model')\n",
    "for synset in synsets:\n",
    "    for i in synset.lemma_names():\n",
    "        print(i)"
   ]
