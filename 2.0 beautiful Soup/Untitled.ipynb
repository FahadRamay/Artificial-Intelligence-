   "source": [
    "from bs4 import BeautifulSoup\n",
    "import requests\n",
    "response=requests.get('https://www.bbc.com/news')\n",
    "content=response.text\n",
    "soup=BeautifulSoup(content,'html.parser')\n",
    "data=soup.find_all('li')\n",
    "for i in data:\n",
    "    print(i.get_text())\n"
   ]
