   "source": [
    "# Python program to explain cv2.imshow() method \n",
    "\n",
    "# importing cv2 \n",
    "import cv2 \n",
    "\n",
    "\n",
    "image = cv2.imread('a.jpg') \n",
    "\n",
    "cv2.imshow('window_name', image) \n",
    "\n",
    "cv2.waitKey(0) \n",
    "\n",
    "# closing all open windows \n",
    "cv2.destroyAllWindows() "
   ]
