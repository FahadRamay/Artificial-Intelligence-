   "source": [
    "import cv2\n",
    "\n",
    "# Create a blank image\n",
    "image = cv2.imread('a.jpg')\n",
    "\n",
    "# Draw a circle on the image\n",
    "cv2.circle(image, (250, 250), 300, (0, 255, 0), 2)\n",
    "\n",
    "# Display the image\n",
    "cv2.imshow('Circle', image)\n",
    "cv2.waitKey(0)\n",
    "cv2.destroyAllWindows()\n"
   ]
  },
